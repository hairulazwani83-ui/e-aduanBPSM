# ============================================================
# Sistem eAduan Kerosakan ICT - Environment Variables Example
# Copy this file to `.env` and fill in your actual values
# NEVER commit the real `.env` file to git
# ============================================================

# ----- Supabase PostgreSQL -----
# Get these from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the pooler URL (port 5432 or 6543) for serverless/edge deployments
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres"

# ----- Supabase Project Info -----
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# ----- NextAuth.js -----
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-strong-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
