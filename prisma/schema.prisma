// Sistem eAduan Kerosakan ICT - ADTEC JTM Kampus Pasir Gudang
// Prisma Schema - PostgreSQL (Supabase)
// Native UUID PKs, enums, and cascade deletes for production-grade schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== User / Profile ====================
model Profile {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  fullName     String
  staffId      String
  department   String
  phone        String?
  role         Role     @default(REPORTER)
  isActive     Boolean  @default(true)
  failedLoginAttempts Int @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  complaints           Complaint[]     @relation("ReporterComplaints")
  assignedComplaints   Complaint[]     @relation("TechnicianComplaints")
  workLogs             WorkLog[]
  statusChanges        StatusHistory[] @relation("StatusChanges")
  suggestions          Suggestion[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  ratingGiven          ComplaintRating[]

  @@index([role])
  @@index([department])
}

// ==================== Equipment Types ====================
model EquipmentType {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique // EQ-01, EQ-02, ...
  name      String
  icon      String   @default("Monitor")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  assets     Asset[]
  complaints Complaint[]

  @@index([isActive])
}

// ==================== Damage Categories ====================
model DamageCategory {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  defaultPriority Priority @default(SEDERHANA)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  complaints Complaint[]

  @@index([isActive])
}

// ==================== Assets (ICT equipment records) ====================
model Asset {
  id               String       @id @default(uuid()) @db.Uuid
  assetTag         String       @unique
  equipmentTypeId  String       @db.Uuid
  brandModel       String
  location         String
  purchaseDate     DateTime?
  status           AssetStatus  @default(AKTIF)
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  equipmentType EquipmentType @relation(fields: [equipmentTypeId], references: [id])
  complaints    Complaint[]

  @@index([equipmentTypeId])
  @@index([status])
  @@index([location])
}

// ==================== Complaints (tickets) ====================
model Complaint {
  id                  String        @id @default(uuid()) @db.Uuid
  ticketNo            String        @unique // ADT-PG-YYYYMM-XXXX
  reporterId          String        @db.Uuid
  equipmentTypeId     String        @db.Uuid
  assetId             String?       @db.Uuid
  damageCategoryId    String        @db.Uuid
  description         String
  aiSuggestedCategory String?
  aiSuggestedPriority String?
  aiSolution          String?
  priority            Priority      @default(SEDERHANA)
  location            String
  status              ComplaintStatus @default(BARU)
  assignedTo          String?       @db.Uuid
  attachmentUrl       String?
  reporterRating      Int?
  reporterFeedback    String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  assignedAt          DateTime?
  resolvedAt          DateTime?
  closedAt            DateTime?

  reporter        Profile        @relation("ReporterComplaints", fields: [reporterId], references: [id])
  technician      Profile?       @relation("TechnicianComplaints", fields: [assignedTo], references: [id])
  equipmentType   EquipmentType  @relation(fields: [equipmentTypeId], references: [id])
  asset           Asset?         @relation(fields: [assetId], references: [id])
  damageCategory  DamageCategory @relation(fields: [damageCategoryId], references: [id])
  workLogs        WorkLog[]
  statusHistory   StatusHistory[]
  ratings         ComplaintRating[]

  @@index([status])
  @@index([priority])
  @@index([reporterId])
  @@index([assignedTo])
  @@index([createdAt])
  @@index([equipmentTypeId])
  @@index([damageCategoryId])
}

// ==================== Work Logs (maintenance work & costs) ====================
model WorkLog {
  id           String   @id @default(uuid()) @db.Uuid
  complaintId  String   @db.Uuid
  technicianId String   @db.Uuid
  actionTaken  String
  cost         Decimal  @default(0) @db.Decimal(10, 2)
  spareParts   String?
  loggedAt     DateTime @default(now())

  complaint  Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  technician Profile   @relation(fields: [technicianId], references: [id])

  @@index([complaintId])
  @@index([technicianId])
  @@index([loggedAt])
}

// ==================== Status History (audit trail) ====================
model StatusHistory {
  id          String   @id @default(uuid()) @db.Uuid
  complaintId String   @db.Uuid
  oldStatus   String?
  newStatus   String
  changedById String   @db.Uuid
  note        String?
  changedAt   DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  changedBy Profile   @relation("StatusChanges", fields: [changedById], references: [id])

  @@index([complaintId])
  @@index([changedAt])
}

// ==================== Suggestions (user feedback) ====================
model Suggestion {
  id            String              @id @default(uuid()) @db.Uuid
  submittedById String              @db.Uuid
  subject       String
  message       String
  category      SuggestionCategory  @default(UMUM)
  adminResponse String?
  status        SuggestionStatus    @default(BARU)
  createdAt     DateTime            @default(now())
  respondedAt   DateTime?

  submittedBy Profile @relation(fields: [submittedById], references: [id])

  @@index([status])
  @@index([submittedById])
}

// ==================== Notifications ====================
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ==================== Complaint Ratings ====================
model ComplaintRating {
  id           String   @id @default(uuid()) @db.Uuid
  complaintId  String   @db.Uuid
  userId       String   @db.Uuid
  rating       Int // 1-5
  feedback     String?
  createdAt    DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user      Profile   @relation(fields: [userId], references: [id])

  @@unique([complaintId, userId])
  @@index([complaintId])
}

// ==================== Audit Log (security & integrity) ====================
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  action    String
  entity    String?
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  severity  Severity @default(INFO)
  createdAt DateTime @default(now())

  user Profile? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([severity])
}

// ==================== Enums ====================
enum Role {
  REPORTER
  TECHNICIAN
  ADMIN
  MANAGEMENT
}

enum Priority {
  RENDAH
  SEDERHANA
  TINGGI
  KRITIKAL
}

enum ComplaintStatus {
  BARU
  DITUGASKAN
  DALAM_TINDAKAN
  ON_HOLD
  SELESAI
  DITUTUP
}

enum AssetStatus {
  AKTIF
  ROSAK
  DILUPUS
}

enum SuggestionCategory {
  UMUM
  PENINGKATAN
  ADUAN_PERKHIDMATAN
}

enum SuggestionStatus {
  BARU
  DALAM_SEMAKAN
  DIJAWAB
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum Severity {
  INFO
  WARNING
  CRITICAL
}
